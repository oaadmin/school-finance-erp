# API Authentication Keys (comma-separated for multiple keys)
# Generate new keys with: node -e "console.log('oa_' + require('crypto').randomBytes(24).toString('hex'))"
API_KEYS=oa_sk_live_your_key_here

# Set to "true" to enforce API key auth on all /api/* routes
# Set to "false" to allow unauthenticated access (dev mode)
API_AUTH_ENABLED=false
